---
import { Image } from "astro:assets";
import pluginwizardLogo from "../../../public/pluginwizard.png";
---

<a class="site-title sl-flex">
  <Image
    inferSize
    priority
    class="print:block"
    alt="PluginWizard Logo"
    src={pluginwizardLogo}
  />
  <span class="notranslate" translate="no">PluginWizard</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: var(--sl-nav-gap);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }
  span {
    overflow: hidden;
    font-weight: bold;
  }
  img {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: 0 50%;
  }
</style>